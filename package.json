{
  "name": "pikachu-volleyball",
  "version": "1.0.10",
  "description": "Pikachu Volleyball implemented into JavaScript by reverse engineering the original game",
  "private": true,
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "oxlint",
    "format": "oxfmt -w src vite.config.ts",
    "format:check": "oxfmt --check src vite.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gorisanson/pikachu-volleyball.git"
  },
  "keywords": [
    "game"
  ],
  "author": "Kyutae Lee",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/gorisanson/pikachu-volleyball/issues"
  },
  "homepage": "https://github.com/gorisanson/pikachu-volleyball#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0"
  },
  "dependencies": {
    "@pixi/canvas-display": "^6.4.2",
    "@pixi/canvas-prepare": "^6.4.2",
    "@pixi/canvas-renderer": "^6.4.2",
    "@pixi/canvas-sprite": "^6.4.2",
    "@pixi/constants": "^6.4.2",
    "@pixi/core": "^6.4.2",
    "@pixi/display": "^6.4.2",
    "@pixi/loaders": "^6.4.2",
    "@pixi/prepare": "^6.4.2",
    "@pixi/settings": "^6.4.2",
    "@pixi/sound": "^4.2.1",
    "@pixi/sprite": "^6.4.2",
    "@pixi/sprite-animated": "^6.4.2",
    "@pixi/spritesheet": "^6.4.2",
    "@pixi/ticker": "^6.4.2"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  }
}
